# 聊天模型配置（必填）
# CHAT_PROVIDER 可选: openai, deepseek, qwen
CHAT_PROVIDER=openai
CHAT_API_KEY=your_chat_api_key
CHAT_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4.1-mini

# DeepSeek 示例：
# CHAT_PROVIDER=deepseek
# CHAT_API_KEY=your_deepseek_api_key
# CHAT_BASE_URL=https://api.deepseek.com
# CHAT_MODEL=deepseek-chat
# 也可以不设 CHAT_API_KEY，用提供者专属变量：
# DEEPSEEK_API_KEY=your_deepseek_api_key

# Qwen 示例：
# CHAT_PROVIDER=qwen
# CHAT_API_KEY=your_dashscope_api_key
# CHAT_MODEL=qwen-max
# 也可以不设 CHAT_API_KEY，用提供者专属变量：
# DASHSCOPE_API_KEY=your_dashscope_api_key

# 向量模型配置（可选，不填则沿用聊天配置）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# 视觉模型配置（可选，不填则沿用聊天配置）
# 用于 MarkItDown OCR，处理 PDF/图片中的内容
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=zai-org/GLM-4.6V

# 代理配置 (不再在代码中显式对齐，如有需要请使用全局环境变量 HTTP_PROXY)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# RAG 配置
KNOWLEDGE_DIR=data/knowledge
VECTOR_STORE_PATH=.cache/vector_store.json
RAG_TOP_K=4
RAG_CHUNK_SIZE=400
RAG_CHUNK_OVERLAP=80

# 和风天气配置
QWEATHER_PROJECT_ID=your_qweather_project_id
QWEATHER_KEY_ID=your_qweather_key_id
# 填写 Ed25519 私钥文件路径
QWEATHER_PRIVATE_KEY_PATH=
# 使用控制台中分配的专属 API Host，例如 https://abcxyz.qweatherapi.com
QWEATHER_API_HOST=https://your-api-host.qweatherapi.com
QWEATHER_JWT_TTL_SECONDS=900
WEATHER_LANG=zh
WEATHER_UNIT=m
WEATHER_FORECAST_DAYS=3
WEATHER_TIMEOUT_SECONDS=10
