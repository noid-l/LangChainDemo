# 聊天模型配置
OPENAI_API_KEY=your_chat_api_key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# 如果你用 DeepSeek 的 OpenAI 兼容接口，可改成下面这种：
# OPENAI_API_KEY=your_deepseek_api_key
# OPENAI_API_BASE=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat

# Embedding 配置
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_API_BASE=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 代理配置，按实际情况填写
OPENAI_PROXY=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
NO_PROXY=localhost,127.0.0.1

# RAG 配置
KNOWLEDGE_DIR=data/knowledge
VECTOR_STORE_PATH=.cache/vector_store.json
RAG_TOP_K=4
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120

# 和风天气配置
QWEATHER_PROJECT_ID=your_qweather_project_id
QWEATHER_KEY_ID=your_qweather_key_id
# 二选一：直接填 PEM 私钥内容，或填写私钥文件路径
QWEATHER_PRIVATE_KEY=
QWEATHER_PRIVATE_KEY_PATH=
# 使用控制台中分配的专属 API Host，例如 https://abcxyz.qweatherapi.com
QWEATHER_API_HOST=https://your-api-host.qweatherapi.com
QWEATHER_JWT_TTL_SECONDS=900
WEATHER_LANG=zh
WEATHER_UNIT=m
WEATHER_FORECAST_DAYS=3
WEATHER_TIMEOUT_SECONDS=10
