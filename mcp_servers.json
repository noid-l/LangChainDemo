{
  "mcpServers": {
    "memory": {
      "command": "python",
      "args": ["-m", "chainmaster.mcp.server.memory"],
      "env": {
        "MEMORY_PATH": "~/.chainmaster/memory_graph.json"
      }
    },
    "filesystem": {
      "command": "python",
      "args": ["-m", "chainmaster.mcp.server.filesystem"],
      "env": {
        "MCP_FS_ROOT": "data/sandbox/"
      }
    }
  }
}
